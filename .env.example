# SyncDocs Environment Configuration

# Backend
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/syncdocs
DB_USERNAME=syncdocs
DB_PASSWORD=syncdocs

# Apache Kafka (KRaft mode)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MinIO Object Store
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=syncdocs
MINIO_SECRET_KEY=syncdocs-secret
MINIO_BUCKET=syncdocs-documents

# JWT
JWT_SECRET=replace-with-your-own-256-bit-secret-key
JWT_EXPIRATION=86400000

# Docker image tags (for production)
BACKEND_IMAGE=syncdocs-backend:latest
FRONTEND_IMAGE=syncdocs-frontend:latest
